PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=a9_calculator

# ─── AI 分析（DeepSeek / OpenAI SDK 兼容） ───────────────────────────────────────
# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=
# 可选：DeepSeek Base URL（默认 https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：模型（默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# ─── 行情 API（可在请求里覆盖 apiBase） ──────────────────────────────────────────
# BINANCE_API_BASE=https://api.binance.com
# 也可以填 OKX，例如：https://www.okx.com（服务端会自动适配 OKX 的接口格式）
# BINANCE_API_BASE=https://www.okx.com
